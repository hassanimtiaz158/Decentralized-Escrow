# Copy this file to `.env` and fill in your deployed contract details.
# Vercel reads these at BUILD time and inlines them into the static bundle.
# Only VITE_-prefixed vars are exposed to the browser — that's fine here
# because the contract address and RPC URL are public on-chain data.
# NEVER put a private key (SEPOLIA_PRIVATE_KEY) in a VITE_ variable.

# Address of the deployed Escrow contract on Sepolia (required).
VITE_APP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: a public Sepolia RPC used only for the "add network" suggestion.
# The app actually talks to the chain through the user's MetaMask (window.ethereum).
VITE_APP_SEPOLIA_RPC_URL=https://sepolia.drpc.org

# Optional: Sepolia chain id (default 11155111).
VITE_APP_CHAIN_ID=11155111
